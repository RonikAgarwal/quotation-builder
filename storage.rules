rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /quotations/{allPaths=**} {
      allow read: if true;
      allow write: if true; // allow anonymous upload for now for quotations
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
